#!/usr/bin/env bash
set -euo pipefail

echo ""
echo "┌──────────────────────────────────────────────────┐"
echo "│           Pre-Push Gate: Ironclad CI              │"
echo "└──────────────────────────────────────────────────┘"
echo ""

# Coverage tooling is mandatory — ci-test silently skips coverage without it
if ! command -v cargo-llvm-cov &>/dev/null; then
    echo "ERROR: cargo-llvm-cov is not installed."
    echo "       Both coverage gates (80% floor + no regression) are required for push."
    echo "       Install: cargo install cargo-llvm-cov"
    exit 1
fi

# Baseline file is mandatory — without it the regression gate is skipped
if [ ! -f ".coverage-baseline" ]; then
    echo "ERROR: .coverage-baseline file not found."
    echo "       The no-regression coverage gate requires a baseline."
    echo "       Create one: just coverage-update-baseline"
    exit 1
fi

MODE="${IRONCLAD_PREPUSH_MODE:-fast}"
if [ "$MODE" = "full" ]; then
    GATE_CMD="just ci-test"
else
    GATE_CMD="just ci-test-fast"
fi

# Auto-tune local test parallelism unless the user set it explicitly.
if [ -z "${CI_TEST_PARALLELISM:-}" ]; then
    CORES=""
    if command -v nproc >/dev/null 2>&1; then
        CORES=$(nproc)
    elif command -v sysctl >/dev/null 2>&1; then
        CORES=$(sysctl -n hw.ncpu 2>/dev/null || true)
    fi
    if [ -n "${CORES}" ] && [ "${CORES}" -gt 0 ] 2>/dev/null; then
        # Keep some headroom for linker + OS responsiveness.
        PAR=$((CORES - 2))
        if [ "${PAR}" -lt 4 ]; then PAR=4; fi
        if [ "${PAR}" -gt 16 ]; then PAR=16; fi
        export CI_TEST_PARALLELISM="${PAR}"
    fi
fi

echo "Mode: ${MODE}"
echo "CI_TEST_PARALLELISM: ${CI_TEST_PARALLELISM:-default}"
echo "Running: ${GATE_CMD}"
echo ""

if eval "$GATE_CMD"; then
    echo ""
    echo "✔ Pre-push gate passed — pushing."
else
    echo ""
    echo "✘ Pre-push gate FAILED — push blocked."
    echo "  Fix the failures above and try again."
    echo "  To bypass (emergency only): git push --no-verify"
    echo "  To run full local gate explicitly: IRONCLAD_PREPUSH_MODE=full git push"
    exit 1
fi
